{
	"version": 6,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 24,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "build",
			"displayName": "Build",
			"binaryDir": "${sourceDir}/build",
			"cacheVariables": {
				"SkyrimSE_PATH": {
					"type": "PATH",
					"value": "$env{SkyrimSE_PATH}"
				}
			}
		}
	],
	"buildPresets": [
		{
			"name": "release",
			"displayName": "Release",
			"configurePreset": "build"
		}
	]
}
